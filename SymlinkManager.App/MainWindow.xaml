<Window x:Class="SymlinkManager.App.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:SymlinkManager.App"
             xmlns:converters="clr-namespace:SymlinkManager.App.Converters"
             mc:Ignorable="d"
             Title="符号链接管理器" Height="700" Width="1100">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:LinkStatusStyleConverter x:Key="LinkStatusStyleConverter" />

        <!-- 标签样式 -->
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="BorderBrush" Value="#0078D4" />
                                <Setter Property="Background" Value="#E6F0FA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <ToolBar Grid.Row="0" Band="1" BandIndex="1">
            <TextBlock Text="搜索:" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox Width="220" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            <Separator />
            <Button Command="{Binding CreateNewLinkCommand}" Content="新建链接" />
            <Button Command="{Binding ScanOrRebuildCommand}" Content="{Binding ScanButtonLabel}" />
            <Separator />
            <Button Command="{Binding OpenSettingsCommand}" Content="设置" />
        </ToolBar>

        <!-- 进度条 -->
        <ProgressBar Grid.Row="1" Height="6" IsIndeterminate="{Binding IsScanning}"
                     Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <!-- 主数据表格 -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding LinksView}"
                  SelectedItem="{Binding SelectedLink}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  EnableRowVirtualization="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  RowDetailsVisibilityMode="Collapsed"
                  GridLinesVisibility="None"
                  SelectionMode="Single"
                  BorderThickness="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="链接名称" Binding="{Binding LinkName}" Width="150" />
                <DataGridTextColumn Header="链接路径" Binding="{Binding LinkPath}" Width="*" />
                <DataGridTextColumn Header="目标路径" Binding="{Binding TargetPath}" Width="*" />
                <DataGridTextColumn Header="类型" Binding="{Binding LinkTypeDisplay}" Width="120" />
                <DataGridTextColumn Header="创建时间" Binding="{Binding CreationTime}" Width="120" />
                <DataGridTemplateColumn Header="状态" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="有效" Foreground="Green"
                                           Visibility="{Binding Status, Converter={StaticResource LinkStatusStyleConverter}, ConverterParameter=valid}" />
                                <TextBlock Text="失效" TextDecorations="Strikethrough" Foreground="Gray"
                                           Visibility="{Binding Status, Converter={StaticResource LinkStatusStyleConverter}, ConverterParameter=broken}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding InWhitelist}" Value="True">
                            <Setter Property="Background" Value="#E8F5E9" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.ContextMenu>
                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <MenuItem Header="打开所在位置" Command="{Binding OpenLocationCommand}" />
                    <MenuItem Header="复制链接路径" Command="{Binding CopyLinkPathCommand}" />
                    <MenuItem Header="复制目标路径" Command="{Binding CopyTargetPathCommand}" />
                    <Separator />
                    <MenuItem Header="转换为交接点(/J)" Command="{Binding ConvertToJunctionCommand}" />
                    <MenuItem Header="转换为目录符号链接(/D)" Command="{Binding ConvertToDirectorySymlinkCommand}" />
                    <Separator />
                    <MenuItem Header="添加到白名单" Command="{Binding AddToWhitelistCommand}" />
                    <MenuItem Header="从白名单移除" Command="{Binding RemoveFromWhitelistCommand}" />
                    <Separator />
                    <MenuItem Header="删除符号链接" Command="{Binding DeleteLinkCommand}" />
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

        <!-- 底部：标签切换 + 状态栏 -->
        <Border Grid.Row="3" Background="#FFF" Padding="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0" Margin="0,0,16,0">
                    <RadioButton Content="全部" IsChecked="{Binding ShowAllLinks}"
                                 Style="{StaticResource TabButtonStyle}" Margin="0,0,8,0" />
                    <RadioButton Content="白名单" IsChecked="{Binding ShowWhitelistOnly}"
                                 Style="{StaticResource TabButtonStyle}" />
                </StackPanel>
                <StatusBar Grid.Column="1" HorizontalAlignment="Right">
                    <StatusBarItem>
                        <TextBlock Text="{Binding StatusMessage, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                    </StatusBarItem>
                    <Separator />
                    <StatusBarItem>
                        <TextBlock Text="{Binding ScanProgressText, Mode=OneWay}" />
                    </StatusBarItem>
                    <StatusBarItem>
                        <TextBlock>
                            <Run Text="链接数:" />
                            <Run Text="{Binding Links.Count, Mode=OneWay}" />
                        </TextBlock>
                    </StatusBarItem>
                </StatusBar>
            </Grid>
        </Border>
    </Grid>
</Window>
