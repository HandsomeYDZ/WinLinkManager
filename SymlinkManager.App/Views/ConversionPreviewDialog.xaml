<Window x:Class="SymlinkManager.App.Views.ConversionPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="转换链接类型" Height="200" Width="450"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="14" />
        <Separator />
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="当前类型：" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentTypeDisplay}" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="目标类型：" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding NewTypeDisplay}" />
        </Grid>
        <TextBlock Text="注意：转换操作将删除原有链接并创建新类型链接，期间会创建临时备份交接点保证数据安全。" TextWrapping="Wrap" Foreground="Gray" FontSize="11" />
        <UniformGrid Columns="2" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="确定" Width="80" Margin="0,0,8,0" Click="OnConfirm" IsDefault="True" />
            <Button Content="取消" Width="80" Click="OnCancel" IsCancel="True" />
        </UniformGrid>
    </StackPanel>
</Window>
