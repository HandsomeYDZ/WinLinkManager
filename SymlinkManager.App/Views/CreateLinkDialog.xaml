<Window x:Class="SymlinkManager.App.Views.CreateLinkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:SymlinkManager.Core.Models;assembly=SymlinkManager.Core"
        Title="新建符号链接" Height="280" Width="450"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock Text="链接类型：" />
        <ComboBox ItemsSource="{Binding LinkTypes}" SelectedItem="{Binding LinkType}" />

        <TextBlock Text="链接路径：" />
        <TextBox Text="{Binding LinkPath, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="目标路径：" />
        <TextBox Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" />

        <UniformGrid Columns="2" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="创建" Width="80" Margin="0,0,8,0" Click="OnConfirm" IsDefault="True" />
            <Button Content="取消" Width="80" Click="OnCancel" IsCancel="True" />
        </UniformGrid>
    </StackPanel>
</Window>
