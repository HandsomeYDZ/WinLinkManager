<Window x:Class="SymlinkManager.App.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="550" Width="550"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <ScrollViewer Margin="16">
        <StackPanel>
            <!-- 扫描目录管理 -->
            <GroupBox Header="扫描目录">
                <StackPanel Margin="8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="添加目录..." Command="{Binding AddScanDirCommand}"
                                Width="100" Margin="0,0,8,0" />
                        <Button Content="移除选中" Command="{Binding RemoveScanDirCommand}"
                                Width="80" Margin="0,0,8,0" />
                        <Button Content="切换排除/扫描" Command="{Binding ExcludeScanDirCommand}"
                                Width="110" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding ScanDirectories}"
                             SelectedItem="{Binding SelectedDir}"
                             Height="160">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ExcludeLabel}" Width="40"
                                               Foreground="Red" />
                                    <TextBlock Text="  " />
                                    <TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </GroupBox>

            <!-- 数据目录 -->
            <GroupBox Header="数据目录" Margin="0,12,0,0">
                <StackPanel Margin="8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="数据:" Width="40" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding DataDirPath}" TextTrimming="CharacterEllipsis"
                                   Foreground="Gray" ToolTip="{Binding DataDirPath}" />
                    </StackPanel>
                    <Button Content="打开数据目录" Command="{Binding OpenDataFolderCommand}"
                            Width="110" HorizontalAlignment="Left" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="数据库文件" Margin="0,12,0,0">
                <StackPanel Margin="8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="路径:" Width="40" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding DatabasePath}" TextTrimming="CharacterEllipsis"
                                   Foreground="Gray" ToolTip="{Binding DatabasePath}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="更改数据库路径..." Command="{Binding ChangeDatabasePathCommand}"
                                Width="140" Margin="0,0,8,0" />
                    </StackPanel>
                    <TextBlock Text="更改后请重启应用以生效。" Foreground="Gray" FontSize="12" Margin="0,4,0,0" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="配置文件" Margin="0,12,0,0">
                <StackPanel Margin="8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="路径:" Width="40" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ConfigDirPath}" TextTrimming="CharacterEllipsis"
                                   Foreground="Gray" ToolTip="{Binding ConfigDirPath}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="打开目录" Command="{Binding OpenConfigFolderCommand}"
                                Width="80" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="关于" Margin="0,12,0,0">
                <StackPanel Margin="8">
                    <TextBlock Text="{Binding AppVersion}" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" />
                    <TextBlock Text="提示：部分操作需要管理员权限运行。" Foreground="Gray" FontStyle="Italic" />
                    <TextBlock Text="数据存储在 %LocalAppData%\\SymlinkManager 目录，开发/发布版一致。"
                               Foreground="Gray" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
            </GroupBox>

            <Button Content="关闭" Width="100" HorizontalAlignment="Right"
                    Click="OnClose" IsCancel="True" Margin="0,12,0,0" />
        </StackPanel>
    </ScrollViewer>
</Window>
