<Window x:Class="SymlinkManager.App.Views.DeleteConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认删除" Height="220" Width="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="14" />
        <UniformGrid Columns="2" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="确定删除" Width="80" Margin="0,0,8,0" Click="OnConfirm" IsDefault="True" />
            <Button Content="取消" Width="80" Click="OnCancel" IsCancel="True" />
        </UniformGrid>
    </StackPanel>
</Window>
